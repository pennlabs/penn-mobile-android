<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        tools:visibility="gone"
        android:id="@+id/search_instructions"
        style="@style/SearchInstructions" />

    <include layout="@layout/no_results" />

    <include layout="@layout/loading_panel" />

    <FrameLayout
        android:id="@+id/search_fav_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <android.support.v7.widget.RecyclerView
            android:id="@+id/fragment_search_favorite_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</LinearLayout>