<!DOCTYPE module PUBLIC
    "-//Puppy Crawl//DTD Check Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <module name="TreeWalker">
        <module name="JavadocType"/>
        <module name="JavadocMethod"/>
        <module name="JavadocVariable"/>
        <module name="NewlineAtEndOfFile"/>
        <module name="FileTabCharacter">
            <property name="eachLine" value="true"/>
        </module>
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="caseIndent" value="4"/>
            <property name="throwsIndent" value="4"/>
            <property name="lineWrappingIndentation" value="4"/>
        </module>
        <module name="LineLength">
            <property name="max" value="100"/>
            <property name="ignorePattern" value="^package.*|^import.*|^.*\{[^}]*$"/>
        </module>
        <module name="RegexpSingleline">
            <property name="format" value="true"/>
            <property name="message" value="At least 2 spaces required after comma"/>
            <property name="regexp" value=",&#xD;&#xA;&#x9;&#x9;&#x9;&#x9;"/>
            <property name="ignoreComments" value="true"/>
        </module>
        <module name="ImportOrder"/>
        <module name="JavadocStyle"/>
        <module name="ModifierOrder"/>
        <module name="OuterTypeFilename"/>
        <module name="RedundantImport"/>
        <module name="EmptyBlock"/>
        <module name="EmptyBlockCheck"/>
        <module name="CatchParameterName"/>
        <module name="FinalParameters"/>
        <module name="ParameterNumber"/>
        <module name="MethodLength"/>
        <module name="FileLength"/>
        <module name="ClassDataAbstractionCoupling"/>
        <module name="VisibilityModifier"/>
        <module name="DesignForExtension"/>
        <module name="AvoidStarImport"/>
        <module name="MultipleVariableDeclarations"/>
        <module name="ArrayTypeStyle"/>
        <module name="ArrayTrailingComma"/>
        <module name="AvoidEscapedUnicodeCharacters"/>
        <module name="IllegalInstantiation"/>
        <module name="AvoidInlineConditionals"/>
        <module name="AvoidNestedBlocks"/>
        <module name="AvoidStaticImport"/>
        <module name="AvoidThrowingNewInstanceOfSameException"/>
        <module name="DesignForExtension"/>
        <module name="EqualsHashCode"/>
        <module name="ExplicitInitialization"/>
        <module name="MissingSwitchDefault"/>
        <module name="NeedBraces"/>
        <module name="NoClone"/>
        <module name="OneTopLevelClass"/>
        <module name="SuperClone"/>
        <module name="UnnecessaryParentheses"/>
        <module name="UnnecessarySemicolon"/>
        <module name="UseBlocks"/>
        <module name="WhitespaceAfter"/>
        <module name="WhitespaceAround"/>
    </module>
</module>
